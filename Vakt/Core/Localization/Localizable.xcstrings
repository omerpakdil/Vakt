    "notification.fajr_wake.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لديك %2$d دقيقة للاستيقاظ والاستعداد لصلاة %1$@."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast %2$d Minuten, um aufzustehen und dich auf %1$@ vorzubereiten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You have %2$d minutes to wake up and prepare for %1$@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tienes %2$d minutos para despertar y prepararte para %1$@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu as %2$d minutes pour te réveiller et te préparer pour %1$@."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamu punya %2$d menit untuk bangun dan bersiap untuk %1$@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai %2$d minuti per svegliarti e prepararti per %1$@."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je hebt %2$d minuten om wakker te worden en je voor te bereiden op %1$@."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Tens %2$d minutos para acordar e te preparar para %1$@."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "У тебя %2$d минут, чтобы проснуться и подготовиться к намазу %1$@."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ namazına hazırlanmak için %2$d dakikan var."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "تمہارے پاس جاگنے اور %1$@ کی تیاری کے لیے %2$d منٹ ہیں۔"
          }
        }
      }
    },

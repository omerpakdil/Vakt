    "onboarding.mark_prayer.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ابدأ الصلاة، وضع هاتفك جانبًا، وسجّلها بلمسة واحدة عند الانتهاء."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beginne das Gebet, lege dein Telefon beiseite und trage es danach mit einem Tippen ein."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Begin prayer, set your phone aside, and record it with one tap when you finish."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comienza la oración, deja el teléfono a un lado y regístrala con un toque al terminar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commencez la prière, posez votre téléphone et enregistrez-la d’un geste lorsque vous avez terminé."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mulai salat, letakkan ponselmu, lalu catat dengan satu ketukan setelah selesai."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inizia la preghiera, metti da parte il telefono e registrala con un tocco quando hai finito."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Begin met bidden, leg je telefoon weg en noteer het met één tik wanneer je klaar bent."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Comece a oração, deixe o telefone de lado e registre-a com um toque ao terminar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Начните молитву, отложите телефон и отметьте её одним касанием после завершения."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Namaza başla, telefonunu kenara bırak ve bitirdiğinde tek dokunuşla kaydet."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "نماز شروع کریں، فون ایک طرف رکھ دیں اور مکمل ہونے پر ایک ٹیپ سے درج کریں۔"
          }
        }
      }
    },

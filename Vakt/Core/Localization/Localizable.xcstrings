        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اکاؤنٹ مستقل طور پر حذف کریں؟"
          }
        }
      }
    },
    "account.delete.error": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر حذف حسابك. حاول مرة أخرى."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Konto konnte nicht gelöscht werden. Versuche es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your account could not be deleted. Please try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo eliminar tu cuenta. Inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ton compte n’a pas pu être supprimé. Réessaie."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Akunmu tidak dapat dihapus. Coba lagi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile eliminare il tuo account. Riprova."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je account kon niet worden verwijderd. Probeer opnieuw."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível eliminar a tua conta. Tenta novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось удалить аккаунт. Попробуй ещё раз."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hesabın silinemedi. Lütfen tekrar dene."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اکاؤنٹ حذف نہیں ہو سکا۔ دوبارہ کوشش کریں۔"
          }
        }
      }
    },
    "account.delete.in_progress": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جارٍ حذف حسابك…"
          }
        },

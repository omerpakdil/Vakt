    "onboarding.friends.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أحيانًا يكفي تذكير لطيف."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Manchmal genügt eine sanfte Erinnerung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sometimes, a gentle reminder is enough."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "A veces basta un recordatorio amable."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Parfois, un doux rappel suffit."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Terkadang, pengingat lembut sudah cukup."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "A volte basta un promemoria gentile."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Soms is een vriendelijke herinnering genoeg."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Às vezes, um lembrete gentil basta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Иногда достаточно мягкого напоминания."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bazen küçük bir hatırlatma yeter."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "کبھی کبھی ایک نرم یاد دہانی کافی ہوتی ہے۔"
          }
        }
      }
    },
    "onboarding.gathering.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "شاهد الآخرين يستعدون ويتوضؤون ويصبحون جاهزين. عندما يحين الوقت يمكنك الانضمام إليهم بهدوء."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sieh andere, die sich vorbereiten, Wudu machen und bereit werden. Wenn es Zeit ist, kannst du dich ruhig anschließen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "See others preparing, making wudu, and becoming ready. When it is time, you can quietly join them."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ve a otros preparándose, haciendo wudu y quedando listos. Cuando llegue la hora, podrás unirte en silencio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voyez les autres se préparer, faire leurs ablutions et devenir prêts. Quand l'heure arrive, vous pouvez les rejoindre en silence."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Lihat yang lain bersiap, berwudu, dan menjadi siap. Saat waktunya tiba, kamu bisa bergabung dengan tenang."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vedi gli altri prepararsi, fare wudu e diventare pronti. Quando arriva il momento, puoi unirti in silenzio."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zie anderen zich voorbereiden, wudu doen en klaar worden. Als het tijd is, kun je rustig aansluiten."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Veja outros se preparando, fazendo wudu e ficando prontos. Quando chegar a hora, você pode se juntar em silêncio."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Видьте, как другие готовятся, совершают вуду и становятся готовы. Когда придет время, вы сможете спокойно присоединиться."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hazırlananları, abdest alanları ve hazır olanları gör. Vakit geldiğinde sessizce onlara katılabilirsin."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "دوسروں کو تیاری کرتے، وضو کرتے اور تیار ہوتے دیکھیں۔ وقت آنے پر آپ خاموشی سے ان میں شامل ہو سکتے ہیں۔"
          }
        }
      }
    },

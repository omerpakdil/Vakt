    "onboarding.promise.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مع كل صلاة، خطوة أقرب إليها."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit jedem Gebet ein Stück näher."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A little closer to prayer, every time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un poco más cerca de la oración, cada vez."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À chaque prière, un peu plus proche d’elle."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Sedikit lebih dekat dengan salat, setiap waktu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "A ogni preghiera, un po’ più vicino."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bij elk gebed een beetje dichterbij."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Um pouco mais perto da oração, a cada vez."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "С каждым намазом ещё немного ближе к молитве."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her vakitte, namazına biraz daha yakın."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ہر نماز کے ساتھ، نماز سے کچھ اور قریب۔"
          }
        }
      }
    },
    "onboarding.reminders.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكن لـ Vakt أن ينبهك بلطف قبل الصلاة، ثم يبقى هادئاً عندما يحين وقت وضع الهاتف جانباً. يمكنك إيقاف التذكيرات من My Vakt."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt kann dich vor dem Gebet sanft benachrichtigen und still bleiben, wenn es Zeit ist, das Telefon wegzulegen. Du kannst Erinnerungen jederzeit in My Vakt pausieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt can gently let you know before prayer, then stay quiet when it is time to put the phone away. You can pause reminders anytime from My Vakt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt puede avisarte suavemente antes de la oración y quedarse en silencio cuando llegue el momento de dejar el teléfono. Puedes pausar los recordatorios desde My Vakt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt peut vous prévenir doucement avant la prière, puis rester silencieux quand vient le moment de poser le téléphone. Vous pouvez mettre les rappels en pause depuis My Vakt."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt bisa memberi tahu dengan lembut sebelum salat, lalu tetap diam saat waktunya meletakkan ponsel. Kamu bisa menjeda pengingat kapan saja dari My Vakt."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt può avvisarti con delicatezza prima della preghiera e restare silenzioso quando è il momento di mettere via il telefono. Puoi mettere in pausa i promemoria da My Vakt."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt kan je voor het gebed zacht laten weten dat het tijd wordt en stil blijven wanneer het tijd is om de telefoon weg te leggen. Je kunt herinneringen pauzeren via My Vakt."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Vakt pode avisar você com delicadeza antes da oração e ficar em silêncio quando for hora de deixar o telefone de lado. Você pode pausar os lembretes em My Vakt."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt может мягко сообщить перед молитвой, а затем оставаться тихим, когда пора убрать телефон. Вы можете приостановить напоминания в My Vakt."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt namazdan önce sana nazikçe haber verir, sonra telefonu kenara bırakma vakti geldiğinde sessiz kalır. Hatırlatmaları My Vakt'ten duraklatabilirsin."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt نماز سے پہلے نرمی سے خبر دے سکتا ہے، پھر فون ایک طرف رکھنے کے وقت خاموش رہتا ہے۔ آپ My Vakt سے کبھی بھی یاددہانیاں روک سکتے ہیں۔"
          }
        }
      }
    },
    "onboarding.reminders.body.screen": {

    "social.empty.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضف صديقًا لترى حال صلاته اليوم هنا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge einen Freund hinzu, um hier seinen heutigen Gebetsstatus zu sehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a friend to see today’s prayer status here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade un amigo para ver aquí su estado de oración de hoy."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoute un ami pour voir ici l’état de ses prières aujourd’hui."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tambahkan teman untuk melihat status salat hari ini di sini."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi un amico per vedere qui lo stato delle sue preghiere di oggi."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voeg een vriend toe om hier de gebedsstatus van vandaag te zien."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Adiciona um amigo para veres aqui o estado das orações de hoje."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавь друга, чтобы видеть здесь статус его намазов сегодня."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir arkadaşını eklediğinde bugünkü namaz hâlini burada görürsün."

    "checkin.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "احفظ فقط ما يساعدك على التذكر والعودة برفق."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Halte nur fest, was dir hilft, dich zu erinnern und ruhig zurückzukehren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Save only what helps you remember and return gently."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarda solo lo que te ayude a recordar y volver con calma."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistre seulement ce qui t’aide à te souvenir et à revenir sereinement."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Simpan hanya yang membantumu mengingat dan kembali dengan tenang."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Salva solo ciò che ti aiuta a ricordare e a tornare con serenità."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bewaar alleen wat je helpt te herinneren en rustig terug te keren."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarde apenas o que ajuda você a lembrar e voltar com calma."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сохраняй только то, что помогает помнить и спокойно возвращаться."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sana hatırlamayı ve yeniden dönmeyi kolaylaştıracak kadarını kaydet."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "صرف وہی محفوظ کریں جو یاد رکھنے اور سکون سے لوٹنے میں مدد دے۔"
          }
        }
      }
    },

    "onboarding.location.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يساعد الموقع التقريبي Vakt في إيجاد مواقيت الصلاة المحلية واتجاه القبلة. لا يظهر موقعك الدقيق."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der ungefähre Standort hilft Vakt, lokale Gebetszeiten und die Qibla-Richtung zu finden. Dein genauer Standort wird nie angezeigt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Approximate location helps Vakt find your local prayer times and qibla direction. Your exact location is never shown."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La ubicación aproximada ayuda a Vakt a encontrar tus horarios de oración locales y la dirección de la qibla. Tu ubicación exacta nunca se muestra."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La position approximative aide Vakt à trouver vos horaires de prière locaux et la direction de la qibla. Votre position exacte n'est jamais affichée."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokasi perkiraan membantu Vakt menemukan waktu salat lokal dan arah kiblat. Lokasi tepatmu tidak pernah ditampilkan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La posizione approssimativa aiuta Vakt a trovare gli orari di preghiera locali e la direzione della qibla. La tua posizione esatta non viene mai mostrata."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geschatte locatie helpt Vakt lokale gebedstijden en de qibla-richting te vinden. Je exacte locatie wordt nooit getoond."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A localização aproximada ajuda o Vakt a encontrar seus horários de oração locais e a direção da qibla. Sua localização exata nunca é mostrada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Примерная геолокация помогает Vakt находить местное время молитв и направление киблы. Ваше точное местоположение никогда не показывается."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yaklaşık konum Vakt'in yerel namaz vakitlerini ve kıble yönünü bulmasına yardımcı olur. Tam konumun gösterilmez."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "تقریبی مقام Vakt کو مقامی نماز کے اوقات اور قبلہ رخ تلاش کرنے میں مدد دیتا ہے۔ آپ کا درست مقام کبھی نہیں دکھایا جاتا۔"
          }
        }
      }
    },

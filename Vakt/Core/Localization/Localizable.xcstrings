        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uitnodiging gekoppeld. Jij en %@ kunnen elkaar nu vriendelijk aan het gebed herinneren."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Convite vinculado. Você e %@ agora podem lembrar um ao outro da oração com carinho."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приглашение привязано. Теперь вы и %@ можете мягко напоминать друг другу о намазе."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Davet bağlandı. %@ ile artık birbirinize namazı nazikçe hatırlatabilirsiniz."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "دعوت منسلک ہو گئی۔ آپ اور %@ اب نرمی سے ایک دوسرے کو نماز یاد دلا سکتے ہیں۔"

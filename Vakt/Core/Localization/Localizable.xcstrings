    "social.header.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اطّلع على حال صلاة أصدقائك اليوم، وذكّر بلطف فقط عند بقاء صلاة دون تحديد."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sieh den heutigen Gebetsstatus deiner Freunde und erinnere nur behutsam an offene Gebete."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "See your friends’ prayer status today; gently remind only when one remains unmarked."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mira hoy el estado de oración de tus amigos y recuerda con amabilidad solo lo que siga sin marcar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vois l’état des prières de tes amis aujourd’hui et rappelle doucement celles qui restent non indiquées."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Lihat status salat temanmu hari ini; ingatkan dengan lembut hanya yang belum ditandai."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarda oggi lo stato delle preghiere dei tuoi amici e ricorda con gentilezza solo quelle non segnate."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bekijk vandaag de gebedsstatus van je vrienden en herinner alleen vriendelijk aan wat nog niet is gemarkeerd."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Vê hoje o estado das orações dos teus amigos e lembra com gentileza apenas o que não foi marcado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Смотри статус намазов друзей сегодня и мягко напоминай только о неотмеченных."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Arkadaşlarının bugünkü namaz hâlini gör; eksik kalan vakitte yalnızca nazikçe hatırlat."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آج دوستوں کی نماز کی حالت دیکھو؛ صرف رہ جانے والی نماز کی نرمی سے یاد دہانی کراؤ۔"
          }
        }
      }
    },

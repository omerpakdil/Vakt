    "qibla_locating_message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أمسك الهاتف بثبات لحظة بينما يحدد Vakt موقعك التقريبي."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Halte das Telefon kurz still, während Vakt deinen ungefähren Standort findet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep the phone still for a moment while Vakt finds your approximate location."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén el teléfono quieto un momento mientras Vakt encuentra tu ubicación aproximada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gardez le téléphone immobile un instant pendant que Vakt trouve votre position approximative."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tahan ponsel sebentar saat Vakt mencari perkiraan lokasimu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni fermo il telefono per un momento mentre Vakt trova la tua posizione approssimativa."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Houd de telefoon even stil terwijl Vakt je geschatte locatie vindt."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantenha o telefone parado por um momento enquanto o Vakt encontra sua localização aproximada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подержите телефон спокойно, пока Vakt определяет примерное местоположение."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt yaklaşık konumunu bulurken telefonu kısa bir süre sabit tut."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt آپ کا اندازاً مقام تلاش کر رہا ہے، فون کو لمحہ بھر ثابت رکھیں۔"
          }

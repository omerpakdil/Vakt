    "prayer.header.in_progress.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "شاشتك الهادئة بانتظارك حيث تركتها."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein stiller Bildschirm wartet dort, wo du aufgehört hast."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your quiet screen is waiting where you left it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu pantalla silenciosa te espera donde la dejaste."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ton écran silencieux t’attend là où tu l’as laissé."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Layar heningmu menunggu di tempat terakhir."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo schermo silenzioso ti aspetta dove l’hai lasciato."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je stille scherm wacht waar je gebleven was."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O teu ecrã silencioso espera onde o deixaste."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тихий экран ждёт там, где ты остановился."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sessiz ekranın kaldığın yerde seni bekliyor."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",

      }
    },
    "account.delete.confirm.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم حذف ملفك وصداقاتك وحالات صلاتك وتذكيراتك للأصدقاء وسجلات الصلوات الفائتة نهائيًا. أدِر أي اشتراك نشط بشكل منفصل في App Store."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Profil, Freundschaften, Gebetsstatus, gesendete Erinnerungen und nachzuholende Gebete werden dauerhaft gelöscht. Ein aktives Abo musst du separat im App Store verwalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your profile, friendships, prayer statuses, reminders sent to friends, and makeup prayer records will be permanently deleted. Manage any active subscription separately in the App Store."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu perfil, amistades, estados de oración, recordatorios enviados y oraciones por recuperar se eliminarán permanentemente. Gestiona por separado cualquier suscripción activa en App Store."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ton profil, tes amitiés, tes états de prière, les rappels envoyés et tes prières à rattraper seront supprimés définitivement. Gère séparément tout abonnement actif dans l’App Store."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Profil, pertemanan, status salat, pengingat yang dikirim, dan catatan salat qada akan dihapus permanen. Kelola langganan aktif secara terpisah di App Store."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Profilo, amicizie, stati di preghiera, promemoria inviati e recuperi saranno eliminati definitivamente. Gestisci separatamente l’abbonamento attivo nell’App Store."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je profiel, vriendschappen, gebedsstatussen, verstuurde herinneringen en inhaalgebeden worden definitief verwijderd. Beheer een actief abonnement apart in de App Store."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O teu perfil, amizades, estados de oração, lembretes enviados e orações por repor serão eliminados permanentemente. Gere separadamente qualquer subscrição ativa na App Store."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Профиль, друзья, статусы намаза, отправленные напоминания и записи пропущенных намазов будут удалены навсегда. Активной подпиской нужно управлять отдельно в App Store."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Profilin, arkadaşlıkların, namaz durumların, arkadaşlarına gönderdiğin hatırlatmalar ve kaza kayıtların kalıcı olarak silinir. Aktif aboneliğini App Store’dan ayrıca yönetmelisin."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "پروفائل، دوستیاں، نماز کی حالت، بھیجی گئی یاد دہانیاں اور قضا نمازوں کا ریکارڈ مستقل حذف ہو جائے گا۔ فعال سبسکرپشن App Store میں الگ سے منظم کریں۔"
          }
        }
      }
    },
    "account.delete.confirm.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {

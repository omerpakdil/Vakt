      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستحتاج إلى تسجيل الدخول باستخدام Apple مرة أخرى على هذا الجهاز."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du musst dich auf diesem Gerät erneut mit Apple anmelden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You will need to sign in with Apple again on this device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tendrás que iniciar sesión de nuevo con Apple en este dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu devras te reconnecter avec Apple sur cet appareil."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamu perlu masuk dengan Apple lagi di perangkat ini."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dovrai accedere di nuovo con Apple su questo dispositivo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je moet op dit apparaat opnieuw inloggen met Apple."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Terás de voltar a iniciar sessão com a Apple neste dispositivo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На этом устройстве потребуется снова войти через Apple."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu cihazda yeniden Apple ile giriş yapman gerekir."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اس ڈیوائس پر دوبارہ Apple کے ساتھ سائن ان کرنا ہوگا۔"
          }
        }
      }
    },

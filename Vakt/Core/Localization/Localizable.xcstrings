    "account.delete.authorization_error": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر إكمال التحقق عبر Apple. حاول مرة أخرى."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Apple-Bestätigung konnte nicht abgeschlossen werden. Versuche es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple verification could not be completed. Please try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo completar la verificación de Apple. Inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La vérification Apple n’a pas pu aboutir. Réessaie."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Verifikasi Apple tidak dapat diselesaikan. Coba lagi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile completare la verifica Apple. Riprova."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple-verificatie kon niet worden voltooid. Probeer opnieuw."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível concluir a verificação Apple. Tenta novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось завершить проверку Apple. Попробуй ещё раз."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple doğrulaması tamamlanamadı. Lütfen tekrar dene."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple تصدیق مکمل نہیں ہو سکی۔ دوبارہ کوشش کریں۔"
          }
        }
      }
    },
    "account.delete.authorization.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تابع باستخدام Apple مرة أخرى لتأكيد ملكيتك للحساب وإلغاء وصول Vakt لتسجيل الدخول."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fahre erneut mit Apple fort, um dein Konto zu bestätigen und Vakts Anmeldezugriff zu widerrufen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Continue with Apple again to confirm this account is yours and revoke Vakt’s Apple sign-in access."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Continúa de nuevo con Apple para confirmar que la cuenta es tuya y revocar el acceso de Vakt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Continue à nouveau avec Apple pour confirmer que ce compte est à toi et révoquer l’accès de Vakt."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Lanjutkan lagi dengan Apple untuk mengonfirmasi akun dan mencabut akses masuk Vakt."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Continua di nuovo con Apple per confermare l’account e revocare l’accesso di Vakt."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ga opnieuw verder met Apple om je account te bevestigen en Vakts toegang in te trekken."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Continua novamente com a Apple para confirmar a conta e revogar o acesso do Vakt."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Снова продолжи с Apple, чтобы подтвердить аккаунт и отозвать доступ Vakt."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hesabın sana ait olduğunu doğrulamak ve Vakt’in Apple ile giriş yetkisini kapatmak için yeniden Apple ile devam et."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اکاؤنٹ کی ملکیت کی تصدیق اور Vakt کی Apple رسائی ختم کرنے کے لیے دوبارہ Apple کے ساتھ جاری رکھیں۔"
          }
        }
      }
    },

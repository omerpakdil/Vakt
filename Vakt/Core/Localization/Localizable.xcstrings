        }
      }
    },
    "offline_saf_presence_accessibility": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنت غير متصل. لا يمكن تحديث حضور الصف."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du bist offline. Saf-Präsenz kann nicht aktualisiert werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are offline. Saf presence cannot update."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estás sin conexión. La presencia del Saf no se puede actualizar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous êtes hors ligne. La présence du Saf ne peut pas se mettre à jour."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamu sedang offline. Kehadiran Saf tidak dapat diperbarui."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei offline. La presenza del Saf non può aggiornarsi."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je bent offline. Saf-aanwezigheid kan niet worden bijgewerkt."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você está offline. A presença do Saf não pode atualizar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы офлайн. Присутствие в Сафе не обновляется."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Çevrimdışısın. Saf varlığı güncellenemiyor."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ آف لائن ہیں۔ صف کی موجودگی اپ ڈیٹ نہیں ہو سکتی۔"
          }
        }
      }
    },
    "onboarding.arrival.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يخبرك حين تقترب الصلاة، ثم يبقى معك من البدء إلى الإتمام وتذكّر ما فاتك."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn das Gebet näher rückt, erinnert dich Vakt und bleibt bei dir – vom Beginn bis zum Abschluss und beim Erinnern an Versäumtes."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It lets you know as prayer draws near, then stays with you through beginning, completing, and remembering what was missed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te avisa cuando se acerca la oración y permanece contigo al comenzar, completar y recordar lo que quedó pendiente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il vous prévient à l’approche de la prière, puis vous accompagne pour commencer, terminer et vous souvenir de ce qui a été manqué."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt memberi tahu saat waktu salat mendekat, lalu menemanimu ketika memulai, menyelesaikan, dan mengingat yang terlewat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ti avvisa quando la preghiera si avvicina e resta con te mentre inizi, completi e ricordi ciò che è rimasto indietro."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt laat het weten wanneer het gebed nadert en blijft bij je terwijl je begint, voltooit en onthoudt wat je hebt gemist."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ele avisa quando a oração se aproxima e acompanha você ao começar, concluir e lembrar o que ficou para trás."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Он сообщает о приближении молитвы и остаётся рядом, пока вы начинаете, завершаете и вспоминаете пропущенное."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Namaz yaklaşırken haber verir; başlayana, tamamlayana ve geride kalanı hatırlayana kadar yanında kalır."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "نماز قریب آنے پر یہ آپ کو بتاتا ہے، پھر شروع کرنے، مکمل کرنے اور رہ جانے والی نماز یاد رکھنے تک آپ کے ساتھ رہتا ہے۔"
          }
        }
      }
    },

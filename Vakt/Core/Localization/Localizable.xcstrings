          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Beoordeel Vakt"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Avaliar Vakt"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оценить Vakt"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt'i değerlendir"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt کی درجہ بندی کریں"
          }
        }
      }
    },
    "review.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إذا ساعدك Vakt على العودة إلى الصلاة بسكينة أكبر، فقد تساعد مراجعة قصيرة مسلمًا آخر على العثور عليه."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Vakt dir geholfen hat, ruhiger zum Gebet zurückzukehren, kann eine kurze Bewertung einem anderen Muslim helfen, Vakt zu finden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If Vakt has helped you return to prayer more calmly, a short review can help another Muslim find it too."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si Vakt te ha ayudado a volver a la oración con más calma, una breve reseña puede ayudar a otro musulmán a encontrarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si Vakt t’a aidé à revenir à la prière avec plus de calme, un court avis peut aider un autre musulman à le trouver."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Jika Vakt membantumu kembali ke salat dengan lebih tenang, ulasan singkat dapat membantu Muslim lain menemukannya."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se Vakt ti ha aiutato a tornare alla preghiera con più calma, una breve recensione può aiutare un altro musulmano a trovarlo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als Vakt je heeft geholpen rustiger terug te keren naar het gebed, kan een korte review een andere moslim helpen Vakt te vinden."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Se o Vakt te ajudou a voltar à oração com mais calma, uma breve avaliação pode ajudar outro muçulmano a encontrá-lo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если Vakt помог тебе спокойнее вернуться к намазу, короткий отзыв поможет другому мусульманину найти приложение."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt namaza daha sakin dönmene yardımcı olduysa, kısa bir yorum başka bir Müslümanın da Vakt’i bulmasına yardımcı olabilir."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اگر Vakt نے تمہیں زیادہ سکون کے ساتھ نماز کی طرف لوٹنے میں مدد دی ہے تو مختصر جائزہ کسی اور مسلمان کو بھی اسے تلاش کرنے میں مدد دے سکتا ہے۔"
          }
        }
      }
    },

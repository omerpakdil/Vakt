    "qibla_idle_message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيستخدم Vakt الموقع واتجاه البوصلة فقط أثناء فتح هذه الشاشة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt nutzt Standort und Kompass nur, solange dieser Bildschirm geöffnet ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt will use location and compass heading only while this sheet is open."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt usa ubicación y brújula solo mientras esta pantalla está abierta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt utilise la position et la boussole seulement pendant que cet écran est ouvert."

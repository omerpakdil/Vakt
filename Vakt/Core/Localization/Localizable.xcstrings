    "onboarding.arrival.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "معرفة الوقت هي البداية.\nويبقى Vakt معك بعد ذلك."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Zeit zu kennen ist der Anfang.\nDanach bleibt Vakt an deiner Seite."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Knowing the time is the beginning.\nVakt stays with you after that."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Saber la hora es solo el comienzo.\nVakt sigue contigo después."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connaître l’heure n’est qu’un début.\nVakt reste à vos côtés ensuite."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mengetahui waktunya adalah awal.\nSetelah itu, Vakt tetap menemanimu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Conoscere l’orario è solo l’inizio.\nVakt resta con te anche dopo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De tijd kennen is het begin.\nDaarna blijft Vakt bij je."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Saber a hora é apenas o começo.\nDepois, o Vakt continua com você."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Знать время — это начало.\nVakt остаётся рядом и после."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakti bilmek başlangıç.\nVakt, sonrasına da eşlik eder."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "وقت جاننا صرف آغاز ہے۔\nاس کے بعد بھی Vakt آپ کے ساتھ رہتا ہے۔"
          }
        }
      }
    },
    "onboarding.closing_reminder.approaching.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لست بحاجة إلى فتح التطبيق للإجابة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zum Antworten musst du die App nicht öffnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You don’t need to open the app to answer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No necesitas abrir la app para responder."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous n’avez pas besoin d’ouvrir l’app pour répondre."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamu tidak perlu membuka aplikasi untuk menjawab."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non serve aprire l’app per rispondere."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je hoeft de app niet te openen om te antwoorden."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você não precisa abrir o app para responder."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чтобы ответить, не нужно открывать приложение."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cevabın için uygulamayı açman gerekmez."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "جواب دینے کے لیے ایپ کھولنے کی ضرورت نہیں۔"
          }
        }
      }
    },
    "onboarding.closing_reminder.approaching.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مع اقتراب نهاية وقت الصلاة"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn die Gebetszeit bald endet"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "As the prayer window nears its end"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando el tiempo de oración está por terminar"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À l’approche de la fin du temps de prière"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Saat waktu salat hampir berakhir"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando il tempo della preghiera sta per finire"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als de gebedstijd bijna voorbij is"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando o horário da oração estiver perto do fim"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда время намаза подходит к концу"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaktin sonuna yaklaşırken"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "جب نماز کا وقت ختم ہونے کے قریب ہو"
          }
        }
      }
    },
    "onboarding.closing_reminder.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند اقتراب نهاية وقت الصلاة، يسألك Vakt مرة أخرى؛ ويمكنك الإجابة دون فتح التطبيق."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn sich die Gebetszeit dem Ende nähert, fragt Vakt noch einmal nach. Du kannst antworten, ohne die App zu öffnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "As the prayer window nears its end, Vakt asks once more; you can answer without opening the app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando el tiempo de oración está por terminar, Vakt vuelve a preguntarte; puedes responder sin abrir la app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "À l’approche de la fin du temps de prière, Vakt vous le demande une dernière fois ; vous pouvez répondre sans ouvrir l’app."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Saat waktu salat hampir berakhir, Vakt akan bertanya sekali lagi; kamu bisa menjawab tanpa membuka aplikasi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando il tempo della preghiera sta per finire, Vakt te lo chiede ancora; puoi rispondere senza aprire l’app."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als de gebedstijd bijna voorbij is, vraagt Vakt het nog één keer. Je kunt antwoorden zonder de app te openen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando o horário da oração estiver perto do fim, o Vakt perguntará mais uma vez; você poderá responder sem abrir o app."
          }
        },
        "ru": {
          "stringUnit": {

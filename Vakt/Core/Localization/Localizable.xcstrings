    "reminder.social_note": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تستخدم طلبات الصداقة وتذكيرات الأصدقاء إذن إشعارات النظام أيضًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Freundschaftsanfragen und Erinnerungen von Freunden nutzen ebenfalls die Systemberechtigung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Friend requests and reminders from friends also use the system notification permission."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las solicitudes de amistad y los recordatorios de amigos también usan el permiso del sistema."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les demandes d’amis et leurs rappels utilisent aussi l’autorisation de notification du système."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Permintaan pertemanan dan pengingat dari teman juga memakai izin sistem."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Anche le richieste di amicizia e i promemoria degli amici usano il permesso di sistema."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vriendschapsverzoeken en herinneringen van vrienden gebruiken ook systeemtoestemming."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pedidos de amizade e lembretes de amigos também usam a permissão do sistema."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запросы в друзья и напоминания от друзей также используют системное разрешение."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Arkadaşlık istekleri ve arkadaş hatırlatmaları da sistem bildirim iznini kullanır."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "دوستی کی درخواستیں اور دوستوں کی یاد دہانیاں بھی سسٹم کی اجازت استعمال کرتی ہیں۔"
          }
        }
      }
    },
    "reminder.sound.detail": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم صوت إشعارات iOS لتذكيرات الصلاة المحلية."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Den iOS-Mitteilungston für lokale Gebetserinnerungen verwenden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the iOS notification sound for local prayer reminders."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa el sonido de iOS para los recordatorios locales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilise le son de notification iOS pour les rappels locaux."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan suara notifikasi iOS untuk pengingat lokal."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa il suono di notifica iOS per i promemoria locali."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gebruik het iOS-meldingsgeluid voor lokale herinneringen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa o som de notificação do iOS nos lembretes locais."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Использовать звук iOS для локальных напоминаний."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yerel namaz hatırlatmalarında iOS bildirim sesini kullan."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "مقامی نماز یاد دہانیوں کے لیے iOS کی اطلاع کی آواز استعمال کریں۔"
          }
        }
      }
    },

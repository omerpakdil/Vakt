    "profile.prayer_modal.message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كيف تريد تسجيل هذه الصلاة؟ يمكنك تغييرها لاحقًا."

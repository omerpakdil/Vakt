        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Vakt usa localização e bússola apenas enquanto esta tela está aberta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt использует геолокацию и компас только пока открыт этот экран."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt konum ve pusula yönünü yalnızca bu ekran açıkken kullanır."

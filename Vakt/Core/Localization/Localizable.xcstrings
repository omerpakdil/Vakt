            "state": "translated",
            "value": "Votre récompense est en cours de vérification. Nous vous préviendrons lorsqu’elle sera prête."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Hadiah undanganmu sedang diverifikasi. Kami akan memberi tahu saat siap."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il premio è in fase di verifica. Ti avviseremo quando sarà pronto."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je uitnodigingsbeloning wordt gecontroleerd. We laten het weten zodra die klaar is."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua recompensa está sendo verificada. Avisaremos quando estiver pronta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Награда проверяется. Мы сообщим, когда она будет готова."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Davet ödülün doğrulanıyor. Hazır olduğunda haber vereceğiz."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ کے دعوتی انعام کی تصدیق ہو رہی ہے۔ تیار ہونے پر ہم اطلاع دیں گے۔"
          }
        }
      }
    },

            "state": "translated",
            "value": "يجب أن يتراوح الاسم بين حرف واحد و48 حرفًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Name muss 1 bis 48 Zeichen lang sein."
          }
        },
        "en": {

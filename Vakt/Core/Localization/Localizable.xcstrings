    "onboarding.promise.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "من التذكير إلى البدء، ومن تسجيل يومك إلى دعم بعضكم، يبقى Vakt معك."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Von der Erinnerung über den Beginn und das Festhalten deines Tages bis zur gegenseitigen Unterstützung bleibt Vakt bei dir."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "From the first reminder to beginning, keeping your day, and supporting one another, Vakt stays with you."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desde el recordatorio hasta el comienzo, desde registrar tu día hasta apoyarse mutuamente, Vakt está contigo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Du premier rappel au début de la prière, de son suivi au soutien mutuel, Vakt reste à vos côtés."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Dari pengingat hingga memulai, mencatat harimu, dan saling mendukung, Vakt tetap menemanimu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dal promemoria all’inizio, dalla registrazione della giornata al sostegno reciproco, Vakt resta con te."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Van de herinnering tot het begin, van het bijhouden van je dag tot elkaar steunen: Vakt blijft bij je."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Do lembrete ao início, do registro do seu dia ao apoio mútuo, o Vakt permanece com você."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "От напоминания и начала намаза до записи дня и взаимной поддержки — Vakt остаётся рядом."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hatırlamaktan başlamaya, kaydetmekten birbirinize destek olmaya kadar Vakt yanında."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یاد دہانی سے آغاز تک، دن میں محفوظ کرنے سے ایک دوسرے کی مدد تک، Vakt آپ کے ساتھ رہتا ہے۔"
          }
        }
      }
    },
    "onboarding.promise.eyebrow": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "معك في كل صلاة"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bei jedem Gebet an deiner Seite"

        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gira lentamente finché il segnale arriva in alto."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Draai langzaam tot de markering bovenaan komt."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Vire devagar até o marcador chegar ao topo."

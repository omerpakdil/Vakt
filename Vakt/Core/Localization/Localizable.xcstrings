            "value": "Le nom doit contenir entre 1 et 48 caractères."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Nama harus terdiri dari 1–48 karakter."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il nome deve contenere da 1 a 48 caratteri."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De naam moet 1 tot 48 tekens bevatten."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O nome deve ter entre 1 e 48 caracteres."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Имя должно содержать от 1 до 48 символов."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İsim 1–48 karakter olmalı."
          }
        },

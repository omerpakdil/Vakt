    "qibla_failed_message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر تحديث اتجاه القبلة. تحقّق من إذن الموقع وحاول مرة أخرى."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Qibla-Richtung konnte nicht aktualisiert werden. Prüfe den Standortzugriff und versuche es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Qibla direction could not be updated. Check location access and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo actualizar la dirección de la qibla. Revisa el acceso a la ubicación e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La direction de la qibla n’a pas pu être actualisée. Vérifie l’accès à la position et réessaie."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Arah kiblat tidak dapat diperbarui. Periksa izin lokasi dan coba lagi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile aggiornare la direzione della qibla. Controlla l’accesso alla posizione e riprova."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De qibla-richting kon niet worden vernieuwd. Controleer locatietoegang en probeer opnieuw."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível atualizar a direção da qibla. Verifica o acesso à localização e tenta novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось обновить направление киблы. Проверь доступ к геопозиции и попробуй снова."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kıble yönü güncellenemedi. Konum iznini kontrol edip tekrar dene."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "قبلہ کی سمت تازہ نہیں ہو سکی۔ مقام کی اجازت چیک کرکے دوبارہ کوشش کریں۔"
          }
        }
      }
    },

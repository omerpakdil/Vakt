    "account.validation.username": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يجب أن يتراوح اسم المستخدم بين 3 و24 حرفًا وألا يحتوي إلا على حروف وأرقام و_."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Benutzername muss 3–24 Zeichen lang sein und darf nur Buchstaben, Zahlen und _ enthalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Username must be 3–24 characters and contain only letters, numbers, and _."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El nombre de usuario debe tener 3–24 caracteres y solo letras, números y _."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le nom d’utilisateur doit contenir 3 à 24 caractères : lettres, chiffres et _ uniquement."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Nama pengguna harus 3–24 karakter dan hanya berisi huruf, angka, serta _."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il nome utente deve avere 3–24 caratteri e contenere solo lettere, numeri e _."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De gebruikersnaam moet 3–24 tekens bevatten: alleen letters, cijfers en _."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O nome de utilizador deve ter 3–24 caracteres e apenas letras, números e _."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Имя пользователя: 3–24 символа, только буквы, цифры и _."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kullanıcı adı 3–24 karakter olmalı; yalnızca harf, rakam ve _ içerebilir."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "صارف نام 3–24 حروف کا ہو اور صرف حروف، اعداد اور _ پر مشتمل ہو۔"
          }
        }
      }
    },

    "qibla_unavailable_message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا الجهاز لا يوفر اتجاه البوصلة، لذلك لا يمكن لـ Vakt إرشاد القبلة هنا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Gerät liefert keine Kompassrichtung, daher kann Vakt hier keine Qibla-Führung geben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This device does not provide compass heading, so Vakt cannot guide qibla here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este dispositivo no ofrece rumbo de brújula, así que Vakt no puede guiar la qibla aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cet appareil ne fournit pas le cap de la boussole, donc Vakt ne peut pas guider la qibla ici."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Perangkat ini tidak menyediakan arah kompas, jadi Vakt belum bisa memandu kiblat di sini."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo dispositivo non fornisce la direzione della bussola, quindi Vakt non può guidare la qibla qui."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit apparaat geeft geen kompasrichting, dus Vakt kan de qibla hier niet wijzen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Este dispositivo não fornece direção da bússola, então o Vakt não pode guiar a qibla aqui."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это устройство не передает направление компаса, поэтому Vakt не может показать киблу здесь."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu cihaz pusula yönü sağlamıyor, bu yüzden Vakt burada kıbleyi gösteremez."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ ڈیوائس کمپاس سمت فراہم نہیں کرتی، اس لیے Vakt یہاں قبلہ نہیں دکھا سکتا۔"
          }
        }
      }
    },

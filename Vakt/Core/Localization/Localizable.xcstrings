    "qibla.helper.default": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إرشاد تقريبي. أبق الهاتف مستوياً واستدر ببطء."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ungefähre Führung. Halte das Telefon flach und drehe dich langsam."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Approximate guidance. Keep the phone flat and turn slowly."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guía aproximada. Mantén el teléfono plano y gira despacio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Indication approximative. Gardez le téléphone à plat et tournez lentement."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Panduan perkiraan. Pegang ponsel rata dan putar perlahan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Guida approssimativa. Tieni il telefono piatto e gira lentamente."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Benaderende richting. Houd de telefoon plat en draai langzaam."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Orientação aproximada. Mantenha o telefone plano e vire devagar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ориентир примерный. Держите телефон ровно и поворачивайтесь медленно."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yaklaşık bir yönlendirme. Telefonu düz tut ve yavaşça dön."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "یہ ایک اندازاً رہنمائی ہے۔ فون کو سیدھا رکھیں اور آہستہ مڑیں۔"
          }
        }
      }
    },
    "qibla.helper.poor_signal": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ابتعد عن الأجسام المعدنية إذا بدا الاتجاه غير مستقر."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entferne dich von Metallgegenständen, wenn die Richtung instabil wirkt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move away from metal objects if the direction feels unstable."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aléjate de objetos metálicos si la dirección se siente inestable."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Éloignez-vous des objets métalliques si la direction semble instable."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Jauhkan dari benda logam jika arah terasa tidak stabil."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Allontanati dagli oggetti metallici se la direzione sembra instabile."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ga weg van metalen voorwerpen als de richting instabiel voelt."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Afaste-se de objetos metálicos se a direção parecer instável."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отойдите от металлических предметов, если направление нестабильно."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yön kararsızsa metal eşyalardan uzaklaş."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اگر سمت غیر مستحکم لگے تو دھاتی چیزوں سے دور ہو جائیں۔"
          }
        }
      }
    },
    "qibla.helper.saved_location": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم استخدام آخر موقع محفوظ. اسمح بالموقع مرة أخرى لاتجاه أحدث."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein letzter gespeicherter Standort wird genutzt. Erlaube den Standort erneut für eine frischere Richtung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Using your last saved location. Allow location again for a fresh direction."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se usa tu última ubicación guardada. Permite la ubicación otra vez para una dirección actualizada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre dernière position enregistrée est utilisée. Autorisez de nouveau la position pour une direction fraîche."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Memakai lokasi terakhir yang tersimpan. Izinkan lokasi lagi untuk arah yang lebih baru."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Viene usata l'ultima posizione salvata. Consenti di nuovo la posizione per una direzione aggiornata."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je laatst opgeslagen locatie wordt gebruikt. Sta locatie opnieuw toe voor een actuelere richting."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua última localização salva está sendo usada. Permita a localização novamente para uma direção atualizada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используется последнее сохраненное местоположение. Разрешите геолокацию снова для свежего направления."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Son kayıtlı konumun kullanılıyor. Daha güncel yön için konuma tekrar izin ver."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آخری محفوظ مقام استعمال ہو رہا ہے۔ تازہ سمت کے لیے مقام کی دوبارہ اجازت دیں۔"
          }
        }
      }
    },

    "horizon_empty_accessibility": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا أحد هنا بعد. عند اقتراب %@ سيبدأ الآخرون بالتجمع."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch niemand hier. Wenn %@ näherkommt, beginnen andere sich zu sammeln."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No one here yet. When %@ approaches, others will begin to gather."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay nadie. Cuando se acerque %@, otros empezarán a reunirse."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Personne ici pour l'instant. Quand %@ approche, les autres commenceront à se rassembler."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Belum ada siapa pun. Saat %@ mendekat, yang lain akan mulai berkumpul."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ancora nessuno qui. Quando %@ si avvicina, gli altri inizieranno a raccogliersi."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nog niemand hier. Wanneer %@ dichterbij komt, beginnen anderen samen te komen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda não há ninguém. Quando %@ se aproximar, outros começarão a se reunir."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Здесь пока никого. Когда %@ приблизится, другие начнут собираться."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Henüz kimse yok. %@ yaklaşınca diğerleri de toplanmaya başlar."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ابھی کوئی نہیں۔ جب %@ قریب آئے گی، دوسرے بھی جمع ہونا شروع کریں گے۔"
          }
        }
      }
    },
    "horizon_empty_body": {
      "extractionState": "manual",
      "localizations": {

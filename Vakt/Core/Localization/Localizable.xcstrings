    "referral.code_sheet.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يُربط الرمز بحسابك قبل الشراء. يمكنك أنت ومن دعاك رؤية حالة صلاة بعضكما وإرسال تذكيرات لطيفة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Code wird vor dem Kauf mit deinem Konto verknüpft. Du und die einladende Person könnt euren Gebetsstatus sehen und euch behutsam erinnern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The code is linked to your account before purchase. You and the person who invited you can see each other’s prayer status and send gentle reminders."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El código se vincula a tu cuenta antes de la compra. Tú y la persona que te invitó podrán ver el estado de oración del otro y enviarse recordatorios amables."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le code est lié à votre compte avant l’achat. La personne qui vous a invité et vous pourrez voir le statut de prière de chacun et vous envoyer de doux rappels."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kode ditautkan ke akunmu sebelum pembelian. Kamu dan orang yang mengundangmu dapat melihat status salat satu sama lain dan mengirim pengingat lembut."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il codice viene collegato al tuo account prima dell’acquisto. Tu e chi ti ha invitato potrete vedere lo stato delle preghiere e inviarvi promemoria gentili."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De code wordt vóór de aankoop aan je account gekoppeld. Jij en degene die je uitnodigde kunnen elkaars gebedsstatus zien en vriendelijke herinneringen sturen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O código é vinculado à sua conta antes da compra. Você e quem convidou você poderão ver o estado das orações um do outro e enviar lembretes gentis."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Код привязывается к аккаунту до покупки. Вы и пригласивший вас человек сможете видеть статус намаза друг друга и отправлять мягкие напоминания."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kod satın almadan önce hesabına bağlanır. Davet eden kişiyle birbirinizin namaz durumunu görebilir ve nazikçe hatırlatabilirsiniz."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "کوڈ خریداری سے پہلے آپ کے اکاؤنٹ سے منسلک ہوتا ہے۔ آپ اور دعوت دینے والا ایک دوسرے کی نماز کی کیفیت دیکھ اور نرمی سے یاد دلا سکتے ہیں۔"
          }
        }
      }
    },

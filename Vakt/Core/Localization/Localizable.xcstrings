    "onboarding.placement.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر مكاناً مفتوحاً، ثم تابع نحو الصلاة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle einen freien Platz und gehe dann weiter zum Gebet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select an open place, then continue toward prayer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige un lugar libre y luego continúa hacia la oración."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez une place libre, puis avancez vers la prière."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih tempat yang terbuka, lalu lanjut menuju salat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli un posto libero, poi continua verso la preghiera."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies een open plek en ga dan verder naar het gebed."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha um lugar livre e continue em direção à oração."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите свободное место, затем продолжайте к молитве."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Açık bir yer seç, sonra namaza doğru devam et."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ایک کھلی جگہ منتخب کریں، پھر نماز کی طرف بڑھیں۔"
          }
        }
      }
    },
    "onboarding.placement.body.choose": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الأماكن المفتوحة مضاءة بلطف. اضغط على مكان لتنضم إلى الصف في هذه اللحظة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Freie Plätze sind sanft beleuchtet. Tippe einen an, um dich für diesen Moment dem Saf anzuschließen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open places are softly lit. Tap one to join this Saf for the moment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los lugares libres están suavemente iluminados. Toca uno para unirte al Saf en este momento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les places libres sont doucement éclairées. Touchez-en une pour rejoindre le Saf pour ce moment."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tempat yang terbuka menyala lembut. Ketuk satu untuk bergabung ke Saf saat ini."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I posti liberi sono illuminati con delicatezza. Toccane uno per unirti al Saf in questo momento."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Open plekken zijn zacht verlicht. Tik op een plek om voor dit moment bij de Saf aan te sluiten."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Os lugares livres estão suavemente iluminados. Toque em um para se juntar ao Saf neste momento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Свободные места мягко подсвечены. Нажмите на одно, чтобы присоединиться к Сафу на этот момент."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Açık yerler yumuşakça aydınlatılır. Bu an için safa katılmak üzere birine dokun."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "کھلی جگہیں نرمی سے روشن ہیں۔ اس لمحے صف میں شامل ہونے کے لیے ایک جگہ کو چھوئیں۔"
          }
        }
      }
    },
    "onboarding.placement.body.ready": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يوجد مكان محجوز. عندما تكون مستعداً، اضغط مطولاً لبدء الصلاة وضع الهاتف جانباً."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nichts wird reserviert. Wenn du bereit bist, halte gedrückt, um das Gebet zu beginnen, und lege das Telefon weg."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Nothing is reserved. When you are ready, hold to begin salah and put the phone away."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Nada queda reservado. Cuando estés listo, mantén pulsado para empezar la oración y deja el teléfono."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rien n'est réservé. Quand vous êtes prêt, maintenez pour commencer la prière et posez le téléphone."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak ada tempat yang dipesan. Saat siap, tahan untuk mulai salat dan letakkan ponsel."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nulla viene riservato. Quando sei pronto, tieni premuto per iniziare la preghiera e metti via il telefono."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er wordt niets gereserveerd. Als je klaar bent, houd vast om het gebed te beginnen en leg de telefoon weg."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Nada fica reservado. Quando estiver pronto, segure para começar a oração e deixe o telefone de lado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ничего не закрепляется. Когда будете готовы, удерживайте, чтобы начать молитву, и уберите телефон."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiçbir yer ayrılmış sayılmaz. Hazır olduğunda namaza başlamak için basılı tut ve telefonu kenara bırak."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "کوئی جگہ مخصوص نہیں۔ جب آپ تیار ہوں تو نماز شروع کرنے کے لیے دبائے رکھیں اور فون ایک طرف رکھ دیں۔"
          }
        }
      }
    },

    "referral.center.share.text": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لنتبادل التذكير بالصلاة بلطف في Vakt. رمز دعوتي: %@"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erinnern wir uns in Vakt behutsam ans Gebet. Mein Einladungscode: %@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Let’s gently remind one another to pray in Vakt. My invitation code: %@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recordémonos la oración con cariño en Vakt. Mi código de invitación: %@"
          }
        },
        "fr": {

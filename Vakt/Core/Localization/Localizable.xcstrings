    "profile.completion.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كيف سيتعرّف إليك أصدقاؤك؟"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie sollen dich Freunde finden?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "How should friends know you?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Cómo te encontrarán tus amigos?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Comment vos amis vous trouveront-ils ?"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Bagaimana teman mengenalmu?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Come ti troveranno gli amici?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoe kunnen vrienden je vinden?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Como seus amigos encontrarão você?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Как друзьям найти вас?"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Arkadaşların seni nasıl tanısın?"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "دوست آپ کو کیسے پہچانیں؟"
          }
        }
      }
    },
    "profile.completion.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر الاسم الظاهر واسم مستخدم يمكن لأصدقائك البحث عنه."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle deinen Anzeigenamen und einen Benutzernamen, nach dem Freunde suchen können."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose your display name and a username friends can search."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige tu nombre visible y un usuario que tus amigos puedan buscar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez votre nom affiché et un identifiant que vos amis pourront rechercher."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih nama tampilan dan nama pengguna yang dapat dicari teman."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli il nome visibile e un nome utente che gli amici possano cercare."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies je weergavenaam en een gebruikersnaam waarop vrienden kunnen zoeken."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha seu nome de exibição e um usuário que seus amigos possam buscar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите отображаемое имя и имя пользователя для поиска друзьями."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Görünen adını ve arkadaşlarının arayabileceği bir kullanıcı adı seç."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنا ظاہری نام اور ایسا صارف نام چنیں جسے دوست تلاش کر سکیں۔"
          }
        }
      }
    },

    "notification.prayer_time.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتح Vakt عندما تكون مستعدًا لبدء الصلاة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffne Vakt, wenn du bereit bist, mit dem Gebet zu beginnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Vakt when you are ready to begin prayer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre Vakt cuando estés listo para empezar la oración."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvre Vakt quand tu es prêt à commencer la prière."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Buka Vakt saat kamu siap memulai salat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apri Vakt quando sei pronto per iniziare la preghiera."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Vakt wanneer je klaar bent om met het gebed te beginnen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre o Vakt quando estiveres pronto para começar a oração."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Открой Vakt, когда будешь готов начать намаз."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Namaza başlamak için hazır olduğunda Vakt’i aç."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "نماز شروع کرنے کے لیے تیار ہوں تو Vakt کھولیں۔"
          }
        }
      }
    },
    "notification.saf_opening.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اقتربت صلاة %@. افتح Vakt عندما تكون مستعدًا للاستعداد."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ ist nah. Öffne Vakt, wenn du bereit bist, dich vorzubereiten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ is near. Open Vakt when you are ready to prepare."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ se acerca. Abre Vakt cuando estés listo para prepararte."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ approche. Ouvre Vakt quand tu es prêt à te préparer."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ sudah dekat. Buka Vakt saat kamu siap bersiap."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ si avvicina. Apri Vakt quando sei pronto a prepararti."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ is dichtbij. Open Vakt wanneer je klaar bent om je voor te bereiden."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ está próxima. Abre o Vakt quando estiveres pronto para te preparar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Намаз %@ приближается. Открой Vakt, когда будешь готов подготовиться."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ yaklaşıyor. Hazırlanmak için hazır olduğunda Vakt’i aç."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ قریب ہے۔ تیاری کے لیے تیار ہوں تو Vakt کھولیں۔"
          }
        }
      }
    },
    "offline_saf_presence": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "غير متصل - لا يمكن تحديث حضور الصف"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Offline - Saf-Präsenz kann nicht aktualisiert werden"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Offline - Saf presence cannot update"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin conexión - la presencia del Saf no se puede actualizar"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hors ligne - la présence du Saf ne peut pas se mettre à jour"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Offline - kehadiran Saf tidak dapat diperbarui"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Offline - la presenza del Saf non può aggiornarsi"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Offline - Saf-aanwezigheid kan niet worden bijgewerkt"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Offline - a presença do Saf não pode atualizar"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",

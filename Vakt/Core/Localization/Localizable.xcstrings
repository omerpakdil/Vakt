    "onboarding.closing_reminder.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حتى مع انشغال يومك، تبقى الصلاة أمامك."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Auch an vollen Tagen gerät das Gebet nicht aus dem Blick."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Even on busy days, prayer doesn’t slip from view."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Incluso en días ajetreados, la oración no se pierde de vista."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Même lors des journées chargées, la prière ne disparaît pas de vue."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Meski hari sibuk, salat tetap terlihat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Anche nelle giornate intense, la preghiera non sfugge di vista."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ook op drukke dagen raakt het gebed niet uit beeld."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mesmo nos dias corridos, a oração não sai de vista."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Даже в насыщенный день намаз не теряется из виду."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gün yoğunlaşsa da namaz gözden kaybolmaz."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "دن مصروف ہو تب بھی نماز نظروں سے اوجھل نہیں ہوتی۔"
          }
        }
      }
    },

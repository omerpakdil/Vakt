    "qibla_ready_message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استدر ببطء حتى تصل العلامة إلى الأعلى."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drehe dich langsam, bis die Markierung oben ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn slowly until the marker reaches the top."
          }
        },
        "es": {

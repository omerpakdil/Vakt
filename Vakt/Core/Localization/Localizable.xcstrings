    "saf.completed.accessibility_hint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذه الصلاة مسجلة بالفعل. أعد فتح شاشة الصلاة عند الحاجة فقط."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Gebet ist bereits markiert. Öffne den Gebetsbildschirm nur bei Bedarf erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This prayer is already marked. Reopen the salah screen only if needed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta oración ya está marcada. Reabre la pantalla de oración solo si hace falta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette prière est déjà marquée. Rouvrez l'écran de prière seulement si besoin."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",

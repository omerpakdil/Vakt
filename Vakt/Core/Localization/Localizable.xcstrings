    "onboarding.friends.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اطّلع على حالة صلاة أحبّائك، وذكّروا بعضكم بلطف عند الحاجة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sieh den Gebetsstatus deiner Liebsten und erinnert euch bei Bedarf behutsam."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "See your loved ones’ prayer status and gently remind one another when needed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mira el estado de oración de tus seres queridos y recuérdense con cariño cuando haga falta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voyez où en sont vos proches dans leurs prières et rappelez-vous doucement lorsque c’est nécessaire."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Lihat status salat orang-orang terdekatmu dan saling ingatkan dengan lembut saat diperlukan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarda lo stato delle preghiere dei tuoi cari e ricordatevele con delicatezza quando serve."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bekijk de gebedsstatus van je dierbaren en herinner elkaar er vriendelijk aan wanneer dat nodig is."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Veja o estado das orações de quem você ama e lembrem-se com carinho quando for preciso."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Смотрите статус намаза близких и при необходимости мягко напоминайте друг другу."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sevdiklerinin namaz durumunu gör; gerektiğinde birbirinize nazikçe hatırlatın."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنوں کی نماز کی کیفیت دیکھیں اور ضرورت ہو تو نرمی سے ایک دوسرے کو یاد دلائیں۔"
          }
        }
      }
    },

        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt memakai lokasi dan arah kompas hanya saat layar ini terbuka."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt usa posizione e bussola solo mentre questa schermata è aperta."
          }
        },

            "value": "Invitation liée. %@ et vous pouvez maintenant vous rappeler doucement la prière."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Undangan terhubung. Kamu dan %@ kini dapat saling mengingatkan salat dengan lembut."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Invito collegato. Tu e %@ ora potete ricordarvi la preghiera con delicatezza."

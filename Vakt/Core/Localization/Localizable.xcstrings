    "placement.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط على مكان مضاء بلطف، ثم ضع الهاتف جانباً عندما تكون مستعداً."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe auf einen sanft leuchtenden Platz und lege das Telefon weg, wenn du bereit bist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap a softly lit place, then put the phone away when you are ready."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca un lugar suavemente iluminado y deja el teléfono cuando estés listo/a."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touche une place doucement éclairée, puis pose le téléphone quand tu es prêt(e)."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ketuk tempat yang lembut bercahaya, lalu letakkan ponsel saat kamu siap."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca un posto illuminato con delicatezza, poi metti via il telefono quando sei pronto/a."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tik op een zacht verlichte plek en leg de telefoon weg wanneer je klaar bent."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque em um lugar suavemente iluminado e deixe o telefone de lado quando estiver pronto/a."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Коснитесь мягко подсвеченного места, затем уберите телефон, когда будете готовы."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yumuşak ışıklı bir yere dokun; hazır olduğunda telefonu kenara bırakıp namaza geç."

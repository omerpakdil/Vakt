    "prayer_settings.automatic_note": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ما لم يتبع مسجدك طريقة مختلفة، يختار الوضع التلقائي الطريقة المناسبة لمنطقتك."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn deine Moschee keine andere Methode nutzt, wählt Automatisch die passende Methode für deine Region."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unless your mosque follows a different method, Automatic chooses the approach suited to your region."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Salvo que tu mezquita use otro método, Automático elige el adecuado para tu región."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sauf si ta mosquée suit une autre méthode, Automatique choisit celle adaptée à ta région."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Jika masjidmu tidak memakai metode lain, Otomatis memilih metode yang sesuai wilayahmu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se la tua moschea non segue un altro metodo, Automatico sceglie quello adatto alla tua zona."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tenzij je moskee een andere methode volgt, kiest Automatisch de methode voor jouw regio."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A menos que a tua mesquita siga outro método, Automático escolhe o adequado à tua região."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если твоя мечеть не использует другой метод, режим «Автоматически» выберет подходящий для региона."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Camin farklı bir yöntem kullanmıyorsa Otomatik seçimi bulunduğun bölgeye uygun yaklaşımı belirler."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اگر تمہاری مسجد کوئی مختلف طریقہ استعمال نہیں کرتی تو خودکار انتخاب تمہارے علاقے کے مطابق طریقہ چنتا ہے۔"
          }
        }
      }
    },
    "prayer_settings.header.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُحسب وفق موقعك والطريقة التي تتبعها."
          }

    "auth.sign_in.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "احتفظ بصلواتك في حسابك، وتبادل التذكير بلطف مع أحبّائك."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Halte deine Gebete in deinem Konto fest und erinnert euch mit euren Liebsten behutsam."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep your prayers in your account and gently remind one another with those you love."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarda tus oraciones en tu cuenta y recuérdense con cariño junto a tus seres queridos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Conservez vos prières dans votre compte et rappelez-vous doucement avec vos proches."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Simpan salatmu di akun dan saling ingatkan dengan lembut bersama orang terdekat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Conserva le tue preghiere nel tuo account e ricordatevele con delicatezza insieme ai tuoi cari."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bewaar je gebeden in je account en herinner elkaar er vriendelijk aan met je dierbaren."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarde suas orações na sua conta e lembrem-se com carinho junto de quem você ama."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Храните намазы в своём аккаунте и мягко напоминайте о них друг другу с близкими."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Namazlarını hesabında tut, sevdiklerinle birbirinize nazikçe hatırlatın."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اپنی نمازیں اکاؤنٹ میں محفوظ رکھیں اور اپنوں کے ساتھ نرمی سے ایک دوسرے کو یاد دلائیں۔"
          }
        }
      }
    },

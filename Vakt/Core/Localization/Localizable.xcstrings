    "onboarding.privacy.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنت مع الصف، بينما يبقى اسمك وملفك لديك. عبادتك بينك وبين الله."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du bist mit dem Saf hier, während Name und Profil bei dir bleiben. Deine Anbetung bleibt zwischen dir und Allah."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You're here with the Saf, while your name and profile stay with you. Your worship stays between you and Allah."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estás aquí con el Saf, mientras tu nombre y perfil se quedan contigo. Tu adoración queda entre tú y Allah."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous êtes avec le Saf, tandis que votre nom et votre profil restent avec vous. Votre adoration reste entre vous et Allah."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamu hadir bersama Saf, sementara nama dan profilmu tetap bersamamu. Ibadahmu tetap antara kamu dan Allah."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei qui con il Saf, mentre nome e profilo restano con te. La tua adorazione resta tra te e Allah."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je bent hier met de Saf, terwijl je naam en profiel bij jou blijven. Je aanbidding blijft tussen jou en Allah."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Você está aqui com o Saf, enquanto seu nome e perfil ficam com você. Sua adoração permanece entre você e Allah."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы здесь с Сафом, а ваше имя и профиль остаются у вас. Ваше поклонение остается между вами и Аллахом."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Safın içindesin; adın ve profilin sende kalır. İbadetin seninle Allah arasındadır."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ صف کے ساتھ ہیں، جبکہ آپ کا نام اور پروفائل آپ کے پاس رہتے ہیں۔ آپ کی عبادت آپ اور اللہ کے درمیان رہتی ہے۔"
          }
        }
      }
    },

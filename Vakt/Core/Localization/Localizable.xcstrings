    "onboarding.promise.accessibility.complete": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اكتملت رحلة الصلاة. يبقى Vakt معك في كل خطوة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Gebetsweg ist abgeschlossen. Vakt bleibt bei jedem Schritt an deiner Seite."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The prayer journey is complete. Vakt stays with you through every step."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El recorrido de la oración se completó. Vakt está contigo en cada paso."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le parcours de la prière est terminé. Vakt reste à vos côtés à chaque étape."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Perjalanan salat selesai. Vakt menemanimu di setiap langkah."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il percorso della preghiera è completo. Vakt resta con te a ogni passo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De gebedsreis is voltooid. Vakt blijft bij elke stap bij je."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O caminho da oração foi concluído. O Vakt permanece com você em cada etapa."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Путь намаза завершён. Vakt остаётся рядом на каждом шаге."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Namaz yolculuğu tamamlandı. Bütün yol boyunca Vakt yanında."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "نماز کا سفر مکمل ہوا۔ ہر قدم پر Vakt آپ کے ساتھ رہتا ہے۔"
          }
        }
      }
    },
    "onboarding.promise.accessibility.next_hint": {
      "extractionState": "manual",
      "localizations": {

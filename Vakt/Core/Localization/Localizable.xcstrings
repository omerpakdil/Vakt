    "reminder.master.enabled.detail": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيرسل لك Vakt إشعارًا في الأوقات المحددة أدناه."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt benachrichtigt dich zu den unten gewählten Zeiten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt will notify you at the times selected below."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt te avisará en los momentos seleccionados abajo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt t’enverra une notification aux moments choisis ci-dessous."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt memberi notifikasi pada waktu yang dipilih di bawah."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt ti avviserà negli orari selezionati qui sotto."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt stuurt meldingen op de hieronder gekozen momenten."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Vakt notifica-te nos momentos escolhidos abaixo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt уведомит тебя в выбранное ниже время."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt aşağıda seçtiğin zamanlarda bildirim gönderir."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt نیچے منتخب اوقات پر اطلاع بھیجے گا۔"
          }
        }
      }
    },

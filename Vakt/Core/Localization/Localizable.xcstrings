    "qibla_denied_message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اسمح بإذن الموقع عندما تريد من Vakt إرشادك لاتجاه القبلة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaube den Standort, wenn Vakt dich zur Qibla führen soll."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allow location permission when you want Vakt to guide the qibla direction."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permite la ubicación cuando quieras que Vakt guíe la dirección de la qibla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorisez la position lorsque vous voulez que Vakt guide la direction de la qibla."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Izinkan lokasi saat kamu ingin Vakt memandu arah kiblat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Consenti la posizione quando vuoi che Vakt guidi la direzione della qibla."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sta locatie toe wanneer je wilt dat Vakt de qibla-richting wijst."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Permita a localização quando quiser que o Vakt guie a direção da qibla."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разрешите геолокацию, когда хотите, чтобы Vakt показал направление киблы."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt'in kıble yönünü göstermesini istediğinde konum iznine izin ver."

    "paywall.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يذكّرك Vakt باقتراب الصلاة، ويفسح لك مكانًا للبدء، ويسجّل ما صليت، ويساعدك وأحبّاءك على دعم بعضكم."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt erinnert dich, wenn das Gebet näher rückt, schafft Raum zum Beginnen, hält deine Gebete fest und hilft dir und deinen Liebsten, euch zu unterstützen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt reminds you as prayer approaches, makes space to begin, records what you prayed, and helps you support one another with those you love."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt te avisa cuando se acerca la oración, te ayuda a hacerle espacio, registra lo que has hecho y permite que tú y tus seres queridos se apoyen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt vous rappelle l’approche de la prière, vous aide à lui faire une place, enregistre ce que vous avez accompli et vous permet de vous soutenir avec vos proches."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt mengingatkan saat salat mendekat, memberi ruang untuk memulai, mencatat salatmu, dan membantu kamu serta orang terdekat saling mendukung."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt ti avvisa quando si avvicina la preghiera, ti aiuta a farle spazio, registra ciò che hai eseguito e permette a te e ai tuoi cari di sostenervi."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt herinnert je als het gebed nadert, maakt ruimte om te beginnen, houdt je gebeden bij en helpt jou en je dierbaren elkaar te steunen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Vakt avisa quando a oração se aproxima, ajuda você a abrir espaço, registra o que foi realizado e permite que você e quem ama se apoiem."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt напоминает о приближении намаза, помогает выделить для него время, сохраняет совершённое и помогает вам с близкими поддерживать друг друга."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt yaklaşırken hatırlatır, namaza yer açar, kıldığını kaydeder ve sevdiklerinle birbirinize destek olmanızı sağlar."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt نماز قریب آنے پر یاد دلاتا ہے، آغاز کے لیے جگہ بناتا ہے، ادا کی گئی نماز محفوظ کرتا ہے اور آپ کو اپنوں کے ساتھ ایک دوسرے کی مدد کرنے دیتا ہے۔"
          }
        }
      }
    },
    "paywall.error.activation_failed": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اكتملت عملية الشراء، لكن الاشتراك لم يتفعّل. استعد المشتريات وحاول مرة أخرى."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Kauf wurde abgeschlossen, aber das Abo ist nicht aktiv. Stelle die Käufe wieder her und versuche es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The purchase completed, but the subscription isn’t active. Restore purchases and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La compra se completó, pero la suscripción no está activa. Restaura las compras e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L’achat est terminé, mais l’abonnement n’est pas actif. Restaurez vos achats et réessayez."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pembelian selesai, tetapi langganan belum aktif. Pulihkan pembelian lalu coba lagi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L’acquisto è stato completato, ma l’abbonamento non è attivo. Ripristina gli acquisti e riprova."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De aankoop is voltooid, maar het abonnement is niet actief. Herstel aankopen en probeer opnieuw."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A compra foi concluída, mas a assinatura não está ativa. Restaure as compras e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Покупка завершена, но подписка не активна. Восстановите покупки и попробуйте снова."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Satın alma tamamlandı ancak abonelik etkinleşmedi. Satın alımları geri yükleyip tekrar dene."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "خریداری مکمل ہوئی مگر رکنیت فعال نہیں ہوئی۔ خریداری بحال کر کے دوبارہ کوشش کریں۔"
          }
        }
      }
    },

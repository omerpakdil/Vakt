    "review.action.rate": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قيّم Vakt"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt bewerten"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Rate Vakt"
          }
        },
        "es": {

    "social.add.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ابحث باسم المستخدم. بعد قبول الطلب يمكنكما رؤية حال صلاة بعضكما."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Suche nach Benutzernamen. Nach der Annahme könnt ihr den Gebetsstatus des anderen sehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Search by username. Once accepted, you can see each other’s prayer status."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Busca por nombre de usuario. Al aceptar la solicitud, podréis ver vuestro estado de oración."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Recherche par nom d’utilisateur. Une fois la demande acceptée, vous pourrez voir vos états de prière."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Cari berdasarkan nama pengguna. Setelah diterima, kalian dapat melihat status salat satu sama lain."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cerca per nome utente. Dopo l’accettazione potrete vedere lo stato delle preghiere reciproche."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zoek op gebruikersnaam. Na acceptatie kunnen jullie elkaars gebedsstatus zien."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pesquisa pelo nome de utilizador. Depois de aceitar, poderão ver o estado das orações um do outro."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ищи по имени пользователя. После принятия вы сможете видеть статус намазов друг друга."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kullanıcı adıyla ara. İstek kabul edilince birbirinizin namaz hâlini görebilirsiniz."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "صارف نام سے تلاش کریں۔ درخواست قبول ہونے پر ایک دوسرے کی نماز کی حالت دیکھ سکیں گے۔"
          }
        }
      }
    },

            "value": "عندما يبدأ صديقك اشتراكه الأول، تحصل على شهر مجاني بعد فترة تحقق مدتها 7 أيام."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn dein Freund sein erstes Abo beginnt, erhältst du nach 7 Tagen Prüfung einen kostenlosen Monat."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When your friend starts their first subscription, you earn one free month after a 7-day verification period."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando tu amigo inicie su primera suscripción, recibirás un mes gratis tras 7 días de verificación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque votre ami débute son premier abonnement, vous gagnez un mois gratuit après 7 jours de vérification."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Saat temanmu memulai langganan pertamanya, kamu mendapat satu bulan gratis setelah verifikasi 7 hari."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando il tuo amico inizia il primo abbonamento, ricevi un mese gratuito dopo 7 giorni di verifica."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wanneer je vriend het eerste abonnement start, krijg je na 7 dagen verificatie een gratis maand."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando seu amigo iniciar a primeira assinatura, você ganhará um mês grátis após 7 dias de verificação."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда друг оформит первую подписку, после 7 дней проверки вы получите бесплатный месяц."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Arkadaşın ilk aboneliğini başlattığında, 7 günlük doğrulamanın ardından bir ücretsiz ay kazanırsın."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ کے دوست کی پہلی رکنیت شروع ہونے پر، 7 دن کی تصدیق کے بعد آپ کو ایک ماہ مفت ملے گا۔"
          }
        }
      }
    },
    "referral.center.intro.title": {

    "onboarding.mark_prayer.title": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value" : "عندما يحين الوقت، وجّه كامل انتباهك إلى الصلاة."
          }

    "qibla_calibrating_message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حرّك الهاتف بلطف على شكل رقم ثمانية صغير إذا بدا الاتجاه عالقاً."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bewege das Telefon sanft in einer kleinen Acht, wenn die Richtung festzustecken scheint."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Move the phone gently in a small figure eight if the direction feels stuck."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mueve suavemente el teléfono en forma de ocho pequeño si la dirección parece atascada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déplacez doucement le téléphone en petit huit si la direction semble bloquée."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Gerakkan ponsel perlahan membentuk angka delapan kecil jika arah terasa macet."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Muovi delicatamente il telefono formando un piccolo otto se la direzione sembra bloccata."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Beweeg de telefoon rustig in een kleine acht als de richting vast lijkt te zitten."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Mova o telefone suavemente em forma de oito pequeno se a direção parecer travada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если направление застыло, мягко двигайте телефон небольшой восьмеркой."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yön takılı kalmış gibi görünürse telefonu küçük bir sekiz çizerek yavaşça hareket ettir."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اگر سمت رکی ہوئی لگے تو فون کو آہستہ سے چھوٹے آٹھ کی شکل میں حرکت دیں۔"
          }
        }
      }
    },

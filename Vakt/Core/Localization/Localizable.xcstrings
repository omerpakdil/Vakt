        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mari saling mengingatkan salat dengan lembut di Vakt. Kode undanganku: %@"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ricordiamoci la preghiera con delicatezza su Vakt. Il mio codice: %@"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Laten we elkaar in Vakt vriendelijk aan het gebed herinneren. Mijn code: %@"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Vamos lembrar uns aos outros da oração com carinho no Vakt. Meu código: %@"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Давайте мягко напоминать друг другу о намазе в Vakt. Мой код: %@"

            "value": "Hapus akun secara permanen?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminare definitivamente il tuo account?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je account definitief verwijderen?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminar permanentemente a tua conta?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удалить аккаунт навсегда?"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hesabın kalıcı olarak silinsin mi?"

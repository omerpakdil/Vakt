    "qibla_permission_message": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستخدم Vakt موقعك التقريبي لحساب اتجاه الكعبة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt nutzt deinen ungefähren Standort, um die Richtung zur Kaaba zu berechnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt uses your approximate location to calculate the direction of the Kaaba."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt usa tu ubicación aproximada para calcular la dirección de la Kaaba."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt utilise votre position approximative pour calculer la direction de la Kaaba."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt memakai perkiraan lokasimu untuk menghitung arah Ka'bah."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt usa la tua posizione approssimativa per calcolare la direzione della Kaaba."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt gebruikt je geschatte locatie om de richting naar de Kaaba te berekenen."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O Vakt usa sua localização aproximada para calcular a direção da Kaaba."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt использует примерное местоположение, чтобы рассчитать направление Каабы."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vakt, Kabe yönünü hesaplamak için yaklaşık konumunu kullanır."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",

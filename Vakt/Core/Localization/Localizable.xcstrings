    "insights.footer.private": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تبقى سجلاتك خاصة على هذا الجهاز.\nهي هنا فقط لتساعدك على العودة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Einträge bleiben privat auf diesem Gerät.\nSie sind nur hier, um dir beim Zurückkehren zu helfen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your entries stay private on this device.\nThey are here only to help you return."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus entradas permanecen privadas en este dispositivo.\nEstán aquí solo para ayudarte a volver."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos entrées restent privées sur cet appareil.\nElles sont là seulement pour vous aider à revenir."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Catatanmu tetap pribadi di perangkat ini.\nIni hanya ada untuk membantumu kembali."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le tue voci restano private su questo dispositivo.\nSono qui solo per aiutarti a tornare."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je invoer blijft privé op dit apparaat.\nDie is er alleen om je te helpen terug te keren."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Suas entradas permanecem privadas neste dispositivo.\nElas estão aqui apenas para ajudar você a voltar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваши записи остаются приватными на этом устройстве.\nОни здесь только чтобы помочь вам вернуться."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kayıtların bu cihazda özel kalır.\nYalnızca geri dönmene yardımcı olmak için burada."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ کے اندراجات اس ڈیوائس پر نجی رہتے ہیں۔\nیہ صرف آپ کو واپس آنے میں مدد دینے کے لیے ہیں۔"
          }
        }
      }
    },

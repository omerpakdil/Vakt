{
  "source": "vakt_reflections_v1",
  "approve": true,
  "items": [
    {
      "content_type": "reflection",
      "language_code": "en",
      "text": "May Allah accept this prayer and keep your heart close to Him.",
      "source_title": "Vakt reflection",
      "tags": ["salah", "after_salah", "acceptance", "gratitude"],
      "weight": 90,
      "external_id": "after-salah-acceptance-en",
      "translation_group_id": "after-salah-acceptance",
      "translation_status": "original",
      "translation_source": "vakt"
    },
    {
      "content_type": "reflection",
      "language_code": "tr",
      "text": "Allah namazını kabul etsin ve kalbini Kendisine yakın tutsun.",
      "source_title": "Vakt tefekkürü",
      "tags": ["salah", "after_salah", "acceptance", "gratitude"],
      "weight": 90,
      "external_id": "after-salah-acceptance-tr",
      "translation_group_id": "after-salah-acceptance",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "ar",
      "text": "تقبل الله صلاتك، وجعل قلبك قريباً منه.",
      "source_title": "تأمل من Vakt",
      "tags": ["salah", "after_salah", "acceptance", "gratitude"],
      "weight": 90,
      "external_id": "after-salah-acceptance-ar",
      "translation_group_id": "after-salah-acceptance",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "fr",
      "text": "Qu'Allah accepte cette prière et garde ton coeur proche de Lui.",
      "source_title": "Réflexion Vakt",
      "tags": ["salah", "after_salah", "acceptance", "gratitude"],
      "weight": 90,
      "external_id": "after-salah-acceptance-fr",
      "translation_group_id": "after-salah-acceptance",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "de",
      "text": "Möge Allah dieses Gebet annehmen und dein Herz nahe bei Ihm halten.",
      "source_title": "Vakt-Reflexion",
      "tags": ["salah", "after_salah", "acceptance", "gratitude"],
      "weight": 90,
      "external_id": "after-salah-acceptance-de",
      "translation_group_id": "after-salah-acceptance",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "es",
      "text": "Que Allah acepte esta oración y mantenga tu corazón cerca de Él.",
      "source_title": "Reflexión de Vakt",
      "tags": ["salah", "after_salah", "acceptance", "gratitude"],
      "weight": 90,
      "external_id": "after-salah-acceptance-es",
      "translation_group_id": "after-salah-acceptance",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "it",
      "text": "Che Allah accetti questa preghiera e tenga il tuo cuore vicino a Lui.",
      "source_title": "Riflessione Vakt",
      "tags": ["salah", "after_salah", "acceptance", "gratitude"],
      "weight": 90,
      "external_id": "after-salah-acceptance-it",
      "translation_group_id": "after-salah-acceptance",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "nl",
      "text": "Moge Allah dit gebed aanvaarden en je hart dicht bij Hem houden.",
      "source_title": "Vakt-reflectie",
      "tags": ["salah", "after_salah", "acceptance", "gratitude"],
      "weight": 90,
      "external_id": "after-salah-acceptance-nl",
      "translation_group_id": "after-salah-acceptance",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "pt",
      "text": "Que Allah aceite esta oração e mantenha seu coração perto Dele.",
      "source_title": "Reflexão Vakt",
      "tags": ["salah", "after_salah", "acceptance", "gratitude"],
      "weight": 90,
      "external_id": "after-salah-acceptance-pt",
      "translation_group_id": "after-salah-acceptance",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "ru",
      "text": "Пусть Аллах примет эту молитву и сохранит сердце близким к Нему.",
      "source_title": "Размышление Vakt",
      "tags": ["salah", "after_salah", "acceptance", "gratitude"],
      "weight": 90,
      "external_id": "after-salah-acceptance-ru",
      "translation_group_id": "after-salah-acceptance",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "id",
      "text": "Semoga Allah menerima salatmu dan menjaga hatimu dekat kepada-Nya.",
      "source_title": "Renungan Vakt",
      "tags": ["salah", "after_salah", "acceptance", "gratitude"],
      "weight": 90,
      "external_id": "after-salah-acceptance-id",
      "translation_group_id": "after-salah-acceptance",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "ur",
      "text": "اللہ آپ کی نماز قبول فرمائے اور آپ کے دل کو اپنے قریب رکھے۔",
      "source_title": "Vakt تأمل",
      "tags": ["salah", "after_salah", "acceptance", "gratitude"],
      "weight": 90,
      "external_id": "after-salah-acceptance-ur",
      "translation_group_id": "after-salah-acceptance",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },

    {
      "content_type": "reflection",
      "language_code": "en",
      "text": "Every return to prayer matters. Come back gently, and keep going.",
      "source_title": "Vakt reflection",
      "tags": ["salah", "after_salah", "returning", "steadiness"],
      "weight": 86,
      "external_id": "after-salah-returning-en",
      "translation_group_id": "after-salah-returning",
      "translation_status": "original",
      "translation_source": "vakt"
    },
    {
      "content_type": "reflection",
      "language_code": "tr",
      "text": "Namaza her dönüş kıymetlidir. Sakince dön ve devam et.",
      "source_title": "Vakt tefekkürü",
      "tags": ["salah", "after_salah", "returning", "steadiness"],
      "weight": 86,
      "external_id": "after-salah-returning-tr",
      "translation_group_id": "after-salah-returning",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "ar",
      "text": "كل عودة إلى الصلاة لها قدرها. عُد برفق، وواصل الطريق.",
      "source_title": "تأمل من Vakt",
      "tags": ["salah", "after_salah", "returning", "steadiness"],
      "weight": 86,
      "external_id": "after-salah-returning-ar",
      "translation_group_id": "after-salah-returning",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "fr",
      "text": "Chaque retour à la prière compte. Reviens doucement et continue.",
      "source_title": "Réflexion Vakt",
      "tags": ["salah", "after_salah", "returning", "steadiness"],
      "weight": 86,
      "external_id": "after-salah-returning-fr",
      "translation_group_id": "after-salah-returning",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "de",
      "text": "Jede Rückkehr zum Gebet zählt. Komm sanft zurück und geh weiter.",
      "source_title": "Vakt-Reflexion",
      "tags": ["salah", "after_salah", "returning", "steadiness"],
      "weight": 86,
      "external_id": "after-salah-returning-de",
      "translation_group_id": "after-salah-returning",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "es",
      "text": "Cada regreso a la oración importa. Vuelve con calma y sigue adelante.",
      "source_title": "Reflexión de Vakt",
      "tags": ["salah", "after_salah", "returning", "steadiness"],
      "weight": 86,
      "external_id": "after-salah-returning-es",
      "translation_group_id": "after-salah-returning",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "it",
      "text": "Ogni ritorno alla preghiera conta. Torna con dolcezza e continua.",
      "source_title": "Riflessione Vakt",
      "tags": ["salah", "after_salah", "returning", "steadiness"],
      "weight": 86,
      "external_id": "after-salah-returning-it",
      "translation_group_id": "after-salah-returning",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "nl",
      "text": "Elke terugkeer naar het gebed telt. Keer rustig terug en ga verder.",
      "source_title": "Vakt-reflectie",
      "tags": ["salah", "after_salah", "returning", "steadiness"],
      "weight": 86,
      "external_id": "after-salah-returning-nl",
      "translation_group_id": "after-salah-returning",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "pt",
      "text": "Cada retorno à oração importa. Volte com calma e continue.",
      "source_title": "Reflexão Vakt",
      "tags": ["salah", "after_salah", "returning", "steadiness"],
      "weight": 86,
      "external_id": "after-salah-returning-pt",
      "translation_group_id": "after-salah-returning",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "ru",
      "text": "Каждое возвращение к молитве важно. Возвращайся мягко и продолжай.",
      "source_title": "Размышление Vakt",
      "tags": ["salah", "after_salah", "returning", "steadiness"],
      "weight": 86,
      "external_id": "after-salah-returning-ru",
      "translation_group_id": "after-salah-returning",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "id",
      "text": "Setiap kembali kepada salat itu berarti. Kembalilah dengan lembut, lalu teruskan.",
      "source_title": "Renungan Vakt",
      "tags": ["salah", "after_salah", "returning", "steadiness"],
      "weight": 86,
      "external_id": "after-salah-returning-id",
      "translation_group_id": "after-salah-returning",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "ur",
      "text": "نماز کی طرف ہر واپسی قیمتی ہے۔ نرمی سے لوٹیں اور چلتے رہیں۔",
      "source_title": "Vakt تأمل",
      "tags": ["salah", "after_salah", "returning", "steadiness"],
      "weight": 86,
      "external_id": "after-salah-returning-ur",
      "translation_group_id": "after-salah-returning",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },

    {
      "content_type": "reflection",
      "language_code": "en",
      "text": "Allah's mercy is wider than a difficult day. Begin again with the next prayer.",
      "source_title": "Vakt reflection",
      "tags": ["salah", "after_salah", "mercy", "returning"],
      "weight": 84,
      "external_id": "after-salah-mercy-en",
      "translation_group_id": "after-salah-mercy",
      "translation_status": "original",
      "translation_source": "vakt"
    },
    {
      "content_type": "reflection",
      "language_code": "tr",
      "text": "Allah'ın rahmeti zor bir günden daha geniştir. Bir sonraki namazla yeniden başla.",
      "source_title": "Vakt tefekkürü",
      "tags": ["salah", "after_salah", "mercy", "returning"],
      "weight": 84,
      "external_id": "after-salah-mercy-tr",
      "translation_group_id": "after-salah-mercy",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "ar",
      "text": "رحمة الله أوسع من يوم صعب. ابدأ من جديد مع الصلاة القادمة.",
      "source_title": "تأمل من Vakt",
      "tags": ["salah", "after_salah", "mercy", "returning"],
      "weight": 84,
      "external_id": "after-salah-mercy-ar",
      "translation_group_id": "after-salah-mercy",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "fr",
      "text": "La miséricorde d'Allah dépasse une journée difficile. Recommence avec la prochaine prière.",
      "source_title": "Réflexion Vakt",
      "tags": ["salah", "after_salah", "mercy", "returning"],
      "weight": 84,
      "external_id": "after-salah-mercy-fr",
      "translation_group_id": "after-salah-mercy",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "de",
      "text": "Allahs Barmherzigkeit ist weiter als ein schwerer Tag. Beginne mit dem nächsten Gebet neu.",
      "source_title": "Vakt-Reflexion",
      "tags": ["salah", "after_salah", "mercy", "returning"],
      "weight": 84,
      "external_id": "after-salah-mercy-de",
      "translation_group_id": "after-salah-mercy",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "es",
      "text": "La misericordia de Allah es más amplia que un día difícil. Empieza de nuevo con la próxima oración.",
      "source_title": "Reflexión de Vakt",
      "tags": ["salah", "after_salah", "mercy", "returning"],
      "weight": 84,
      "external_id": "after-salah-mercy-es",
      "translation_group_id": "after-salah-mercy",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "it",
      "text": "La misericordia di Allah è più ampia di una giornata difficile. Ricomincia con la prossima preghiera.",
      "source_title": "Riflessione Vakt",
      "tags": ["salah", "after_salah", "mercy", "returning"],
      "weight": 84,
      "external_id": "after-salah-mercy-it",
      "translation_group_id": "after-salah-mercy",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "nl",
      "text": "Allahs barmhartigheid is ruimer dan een moeilijke dag. Begin opnieuw met het volgende gebed.",
      "source_title": "Vakt-reflectie",
      "tags": ["salah", "after_salah", "mercy", "returning"],
      "weight": 84,
      "external_id": "after-salah-mercy-nl",
      "translation_group_id": "after-salah-mercy",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "pt",
      "text": "A misericórdia de Allah é maior que um dia difícil. Recomece com a próxima oração.",
      "source_title": "Reflexão Vakt",
      "tags": ["salah", "after_salah", "mercy", "returning"],
      "weight": 84,
      "external_id": "after-salah-mercy-pt",
      "translation_group_id": "after-salah-mercy",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "ru",
      "text": "Милость Аллаха шире трудного дня. Начни снова со следующей молитвы.",
      "source_title": "Размышление Vakt",
      "tags": ["salah", "after_salah", "mercy", "returning"],
      "weight": 84,
      "external_id": "after-salah-mercy-ru",
      "translation_group_id": "after-salah-mercy",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "id",
      "text": "Rahmat Allah lebih luas daripada hari yang berat. Mulailah lagi pada salat berikutnya.",
      "source_title": "Renungan Vakt",
      "tags": ["salah", "after_salah", "mercy", "returning"],
      "weight": 84,
      "external_id": "after-salah-mercy-id",
      "translation_group_id": "after-salah-mercy",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "ur",
      "text": "اللہ کی رحمت ایک مشکل دن سے کہیں وسیع ہے۔ اگلی نماز کے ساتھ دوبارہ شروع کریں۔",
      "source_title": "Vakt تأمل",
      "tags": ["salah", "after_salah", "mercy", "returning"],
      "weight": 84,
      "external_id": "after-salah-mercy-ur",
      "translation_group_id": "after-salah-mercy",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },

    {
      "content_type": "reflection",
      "language_code": "en",
      "text": "Fajr begins the day with remembrance before the world becomes loud.",
      "source_title": "Vakt reflection",
      "tags": ["salah", "after_salah", "fajr", "remembrance"],
      "weight": 78,
      "external_id": "fajr-light-en",
      "translation_group_id": "fajr-light",
      "translation_status": "original",
      "translation_source": "vakt"
    },
    {
      "content_type": "reflection",
      "language_code": "tr",
      "text": "Sabah namazı, dünya kalabalıklaşmadan günü zikirle başlatır.",
      "source_title": "Vakt tefekkürü",
      "tags": ["salah", "after_salah", "fajr", "remembrance"],
      "weight": 78,
      "external_id": "fajr-light-tr",
      "translation_group_id": "fajr-light",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "ar",
      "text": "يفتتح الفجر اليوم بالذكر قبل أن يعلو ضجيج الدنيا.",
      "source_title": "تأمل من Vakt",
      "tags": ["salah", "after_salah", "fajr", "remembrance"],
      "weight": 78,
      "external_id": "fajr-light-ar",
      "translation_group_id": "fajr-light",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "fr",
      "text": "Fajr ouvre la journée par le rappel, avant que le monde ne devienne bruyant.",
      "source_title": "Réflexion Vakt",
      "tags": ["salah", "after_salah", "fajr", "remembrance"],
      "weight": 78,
      "external_id": "fajr-light-fr",
      "translation_group_id": "fajr-light",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "de",
      "text": "Fajr beginnt den Tag mit Gedenken, bevor die Welt laut wird.",
      "source_title": "Vakt-Reflexion",
      "tags": ["salah", "after_salah", "fajr", "remembrance"],
      "weight": 78,
      "external_id": "fajr-light-de",
      "translation_group_id": "fajr-light",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "es",
      "text": "Fajr comienza el día con recuerdo antes de que el mundo se vuelva ruidoso.",
      "source_title": "Reflexión de Vakt",
      "tags": ["salah", "after_salah", "fajr", "remembrance"],
      "weight": 78,
      "external_id": "fajr-light-es",
      "translation_group_id": "fajr-light",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "it",
      "text": "Fajr apre il giorno con il ricordo, prima che il mondo diventi rumoroso.",
      "source_title": "Riflessione Vakt",
      "tags": ["salah", "after_salah", "fajr", "remembrance"],
      "weight": 78,
      "external_id": "fajr-light-it",
      "translation_group_id": "fajr-light",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "nl",
      "text": "Fajr begint de dag met gedenken voordat de wereld druk wordt.",
      "source_title": "Vakt-reflectie",
      "tags": ["salah", "after_salah", "fajr", "remembrance"],
      "weight": 78,
      "external_id": "fajr-light-nl",
      "translation_group_id": "fajr-light",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "pt",
      "text": "Fajr começa o dia com recordação antes que o mundo fique barulhento.",
      "source_title": "Reflexão Vakt",
      "tags": ["salah", "after_salah", "fajr", "remembrance"],
      "weight": 78,
      "external_id": "fajr-light-pt",
      "translation_group_id": "fajr-light",
      "translation_status": "machine",
      "translation_source": "vakt-initial-localization"
    },
    {
      "content_type": "reflection",
      "language_code": "ru",
